# Example .env — copy to `.env` (gitignored) and fill in your values.
#
# Required
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=               # comma-separated numeric user IDs, e.g. 5615834073
# Comma-separated if you have multiple allowed users
# TELEGRAM_ALLOWED_USERS=111,222,333

# Optional — adds X-Telegram-Bot-Api-Secret-Token header verification
# TELEGRAM_WEBHOOK_SECRET=any-random-string

# LLM provider — pick one
LLM_PROVIDER=openrouter               # openrouter | groq | mistral | openai | google | anthropic | deepseek | cohere | local
LLM_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4
# LLM_BASE_URL=                        # only for local/custom providers
LLM_MAX_TOKENS=1500

# Server
PORT=8080
HOST=0.0.0.0
